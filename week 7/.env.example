# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Connection
# Option 1: Local MongoDB
MONGODB_URI=mongodb://localhost:27017/product_db

# Option 2: MongoDB Atlas (cloud) - thay thế string bên dưới
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/product_db?retryWrites=true&w=majority

# API Base URL (for Swagger UI)
API_BASE_URL=http://localhost:3000
